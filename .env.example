# Server Configuration
PORT=3458

# Database Configuration
DATABASE_URL=./data/backup.db

# Workspace Configuration
# Format: 'name1:/path1,name2:/path2'
# Example: 'workspace1:/home/user/workspace1,workspace2:/home/user/workspace2'
WORKSPACES=

# Backup Repository Configuration
BACKUP_REPO=

# Git Remote URL
# Example: git@github.com:username/backup-repo.git
GIT_REMOTE=

# SSH Key Path for Git Push
# Example: /home/user/.ssh/id_rsa
SSH_KEY_PATH=

# Backup Schedule (cron expression, default: every hour)
# Examples:
#   0 * * * *      - Every hour (default)
#   */30 * * * *   - Every 30 minutes
#   0 */2 * * *    - Every 2 hours
#   0 */6 * * *    - Every 6 hours
#   0 0 * * *      - Once a day at midnight
BACKUP_CRON=0 * * * *

# Telegram Notification Configuration (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
